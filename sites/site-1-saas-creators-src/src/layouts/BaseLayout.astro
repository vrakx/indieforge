---
import { site, navigation, footerLinks } from '../config/site';
---

<!DOCTYPE html>
<html lang={site.locale} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={site.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={site.url + Astro.url.pathname} />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url + Astro.url.pathname} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <title>{site.title}{Astro.url?.pathname && Astro.url.pathname !== '/' ? ' — ' + Astro.url.pathname.replace(/^\//, '') : ''}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        --color-bg: #0a0a0b;
        --color-surface: #141416;
        --color-surface-elevated: #1c1c1f;
        --color-border: #2a2a2e;
        --color-text: #e4e4e7;
        --color-text-muted: #a1a1aa;
        --color-accent: #6366f1;
        --color-accent-hover: #818cf8;
        --color-success: #22c55e;
        --color-warning: #f59e0b;
        --color-error: #ef4444;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, monospace;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      html { scroll-behavior: smooth; }
      
      body {
        font-family: var(--font-sans);
        background-color: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
        transition: color 0.2s;
      }
      
      a:hover { color: var(--color-accent-hover); }

      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* Typography */
      h1, h2, h3, h4 { font-weight: 600; line-height: 1.3; }
      h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.02em; }
      h2 { font-size: clamp(1.5rem, 3vw, 2rem); letter-spacing: -0.01em; }
      h3 { font-size: 1.25rem; }

      /* Prose */
      .prose { max-width: none; }
      .prose p { margin-bottom: 1.25rem; color: var(--color-text-muted); }
      .prose a { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
      .prose strong { color: var(--color-text); font-weight: 600; }
      .prose ul, .prose ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
      .prose li { margin-bottom: 0.5rem; color: var(--color-text-muted); }
      .prose h2 { margin-top: 2.5rem; margin-bottom: 1rem; color: var(--color-text); }
      .prose h3 { margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-text); }
      .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
      .prose th, .prose td { padding: 0.75rem 1rem; border: 1px solid var(--color-border); text-align: left; }
      .prose th { background: var(--color-surface); font-weight: 600; color: var(--color-text); }
      .prose td { color: var(--color-text-muted); }
      .prose blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; margin: 1.5rem 0; color: var(--color-text-muted); font-style: italic; }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="container" aria-label="Main navigation">
        <a href="/" class="site-logo">{site.title}</a>
        <ul class="nav-links">
          {navigation.navItems.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} {site.author}. All rights reserved.</p>
        <ul>
          {footerLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
        <p class="affiliate-notice">Some links are affiliate links. We earn a commission at no extra cost to you.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    background: rgba(10, 10, 11, 0.85);
    backdrop-filter: blur(12px);
    z-index: 100;
  }

  .site-header nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text) !important;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--color-text-muted) !important;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-text) !important;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
    text-align: center;
  }

  .site-footer p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .affiliate-notice {
    font-size: 0.75rem !important;
    opacity: 0.6;
  }

  .site-footer ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 0.75rem;
  }

  .site-footer ul a {
    color: var(--color-text-muted) !important;
    font-size: 0.85rem;
  }
</style>
