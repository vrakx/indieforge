---
interface Props {
  title: string;
  description: string;
  publishedAt?: string;
  author?: string;
  readingTime?: string;
  tags?: string[];
}

const { title, description, publishedAt, author, readingTime, tags = [] } = Astro.props;
---

<BaseLayout>
  <article class="container" style="max-width:760px;padding-top:3rem;">
    <header style="margin-bottom:2.5rem;">
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        {tags.map(tag => (
          <span style="background:var(--color-surface);border:1px solid var(--color-border);padding:0.25rem 0.75rem;border-radius:999px;font-size:0.75rem;color:var(--color-text-muted);">{tag}</span>
        ))}
      </div>
      <h1 style="margin-bottom:1rem;">{title}</h1>
      <p style="color:var(--color-text-muted);font-size:0.9rem;margin-bottom:0.5rem;">{description}</p>
      {publishedAt && <p style="color:var(--color-text-muted);font-size:0.8rem;">Published: {new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}{author ? ` · ${author}` : ''}{readingTime ? ` · ${readingTime} read` : ''}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>

    <style is:global>
      article { margin-bottom: 4rem; }
      header h1 { color: var(--color-text) !important; }
    </style>
  </article>
</BaseLayout>
