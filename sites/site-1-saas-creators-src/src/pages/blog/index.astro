---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
---

<BaseLayout>
  <div class="container" style="max-width:800px;padding-top:3rem;">
    <h1 style="margin-bottom:0.5rem;">Articles</h1>
    <p style="color:var(--color-text-muted);margin-bottom:2rem;">In-depth reviews and comparisons of SaaS tools for creators and freelancers.</p>

    {sortedPosts.length === 0 ? (
      <p style="color:var(--color-text-muted);">No articles yet. We're working on our first batch!</p>
    ) : (
      <div style="display:grid;gap:1.5rem;">
        {sortedPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="article-card" style="display:block;text-decoration:none;color:inherit;padding:1.25rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;transition:border-color 0.2s;">
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
              {post.data.tags.map(tag => (
                <span style="background:var(--color-surface-elevated);border:1px solid var(--color-border);padding:0.2rem 0.6rem;border-radius:999px;font-size:0.7rem;color:var(--color-text-muted);">{tag}</span>
              ))}
            </div>
            <h3 style="font-size:1.1rem;margin-bottom:0.5rem;color:var(--color-text)">{post.data.title}</h3>
            <p style="color:var(--color-text-muted);font-size:0.85rem;font-weight:400;">{post.data.description}</p>
            <p style="color:var(--color-text-muted);font-size:0.75rem;margin-top:0.75rem;opacity:0.6;">
              {new Date(post.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {post.data.author}
            </p>
          </a>
        ))}
      </div>
    )}

    <style is:global>
      .article-card:hover { border-color: var(--color-accent); }
      h3 { transition: color 0.2s; }
      .article-card:hover h3 { color: var(--color-accent-hover); }
    </style>
  </div>
</BaseLayout>
