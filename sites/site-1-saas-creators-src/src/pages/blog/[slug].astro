---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPaths = await import.meta.glob('/content/blog/*.mdx');
  const sortedEntries = Object.entries(allPaths).sort((a, b) => {
    const aDate = new Date(a[1].frontmatter?.publishedAt || '2026-01-01').getTime();
    const bDate = new Date(b[1].frontmatter?.publishedAt || '2026-01-01').getTime();
    return bDate - aDate;
  });

  return sortedEntries.map(([path]) => ({
    params: { slug: path.replace('/content/blog/', '').replace('.mdx', '') },
  }));
}

const allPaths = await import.meta.glob('/content/blog/*.mdx');
const sortedEntries = Object.entries(allPaths).sort((a, b) => {
  const aDate = new Date(a[1].frontmatter?.publishedAt || '2026-01-01').getTime();
  const bDate = new Date(b[1].frontmatter?.publishedAt || '2026-01-01').getTime();
  return bDate - aDate;
});

const currentPath = `/content/blog/${Astro.params.slug}.mdx`;
const postIndex = sortedEntries.findIndex(([path]) => path === currentPath);
const prevEntry = postIndex > 0 ? sortedEntries[postIndex - 1] : null;
const nextEntry = postIndex < sortedEntries.length - 1 ? sortedEntries[postIndex + 1] : null;

const contentModule = await allPaths[currentPath];
if (!contentModule) {
  Astro.redirect('/404');
}

const fm = contentModule.frontmatter || {};
---

<BaseLayout>
  <div class="container" style="max-width:760px;padding-top:3rem;">
    <article>
      <header style="margin-bottom:2.5rem;">
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
          {(fm.tags || []).map((tag: string) => (
            <span style="background:var(--color-surface);border:1px solid var(--color-border);padding:0.25rem 0.75rem;border-radius:999px;font-size:0.75rem;color:var(--color-text-muted);">{tag}</span>
          ))}
        </div>
        <h1 style="margin-bottom:1rem;">{fm.title || 'Untitled'}</h1>
        <p style="color:var(--color-text-muted);font-size:0.9rem;margin-bottom:0.5rem;">{fm.description || ''}</p>
        <p style="color:var(--color-text-muted);font-size:0.8rem;">Published: {new Date(fm.publishedAt || '2026-05-18').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}{fm.author ? ` · ${fm.author}` : ''}</p>
      </header>

      <div class="prose">
        <slot />
      </div>

      {(prevEntry || nextEntry) && (
        <nav style={{display:'flex',justifyContent:'space-between',marginTop:'3rem',paddingTop:'2rem',borderTop:'1px solid var(--color-border)'}}>
          {prevEntry ? (
            <a href={`/blog/${prevEntry[0].replace('/content/blog/', '').replace('.mdx', '')}`} style={{color:'var(--color-text-muted)',fontSize:'0.9rem'}}>&larr; Previous</a>
          ) : <div />}
          {nextEntry ? (
            <a href={`/blog/${nextEntry[0].replace('/content/blog/', '').replace('.mdx', '')}`} style={{color:'var(--color-text-muted)',fontSize:'0.9rem',textAlign:'right'}}>Next: Next Post &rarr;</a>
          ) : <div />}
        </nav>
      )}
    </article>
  </div>
</BaseLayout>
